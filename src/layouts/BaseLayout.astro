---
import "../styles/global.css";
import "katex/dist/katex.min.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Simon Jisoo Jang",
  description = "PhD researcher portfolio and research notes."
} = Astro.props;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/research/", label: "Research" },
  { href: "/writing/", label: "Writing" },
  { href: "/notes/", label: "Notes" },
  { href: "/cv/", label: "CV" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="alternate" type="application/rss+xml" title="Soopace Writing" href="/rss.xml" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Soopace home">
        <span class="brand-mark">
          <img src="/img/logo/logo.png" alt="" />
        </span>
        <span>Soopace</span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>© {new Date().getFullYear()} Simon Jisoo Jang</p>
      <div>
        <a href="https://github.com/simonjisu">GitHub</a>
      </div>
    </footer>
  </body>
</html>
